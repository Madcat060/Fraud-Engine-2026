# Copy this file to .env before running `docker compose up --build`.
# The defaults below are self-contained and work out of the box with the
# bundled Postgres container.

# --- Postgres container ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Cookies01!
POSTGRES_DB=game_integrity
# Host port to expose Postgres on (container always listens on 5432).
POSTGRES_PORT=5432

# --- Application database URLs ---
# Note: host is "db" (the compose service name), NOT localhost, because the
# app talks to Postgres over the compose network.
DEFAULT_DB_CONNECTION=postgresql+psycopg2://postgres:Cookies01!@db:5432/game_integrity

# Optional: point case-management / collusion data at different databases.
# Leave unset to reuse DEFAULT_DB_CONNECTION.
# CASE_MANAGEMENT_URL=postgresql+psycopg2://postgres:Cookies01!@db:5432/game_integrity
# COLLUSION_DB_URL=postgresql+psycopg2://postgres:Cookies01!@db:5432/game_integrity

# --- Host ports ---
PORT_FRAUD=5001
PORT_REPORTS=5000

# --- External report API (only needed for live Playtech report pulls) ---
# PLAYTECH_ADMIN_USER=PRReports
# PLAYTECH_ADMIN_PASSWORD=changeme
