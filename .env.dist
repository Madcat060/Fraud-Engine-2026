# Template for the local .env file — keys only, NO real secrets.
#
#   cp .env.dist .env      then fill in the values below.
#
# .env is gitignored, so your real credentials never get committed.

# --- Postgres container ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=game_integrity
# Host port to expose Postgres on (container always listens on 5432).
POSTGRES_PORT=5432

# --- Application database URL ---
# Host is "db" (the compose service name), NOT localhost, because the app
# talks to Postgres over the compose network. The password here MUST match
# POSTGRES_PASSWORD above.
DEFAULT_DB_CONNECTION=postgresql+psycopg2://postgres:CHANGE_ME@db:5432/game_integrity

# Optional: point case-management / collusion data at different databases.
# Leave unset to reuse DEFAULT_DB_CONNECTION.
# CASE_MANAGEMENT_URL=
# COLLUSION_DB_URL=

# --- Host ports ---
PORT_FRAUD=5001
PORT_REPORTS=5000

# --- Production image (used by docker-compose.prod.yml) ---
# FRAUD_IMAGE=ghcr.io/madcat060/fraud-engine-2026:latest

# --- External report API (only needed for live Playtech report pulls) ---
# PLAYTECH_ADMIN_USER=
# PLAYTECH_ADMIN_PASSWORD=
